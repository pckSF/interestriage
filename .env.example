# Runtime mode: local or server
INTERESTRIAGE_MODE=local

# API
API_BIND_HOST=127.0.0.1
API_PORT=8000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:8080

# Limits
RATE_LIMIT_PER_MINUTE=240
MAX_UPLOAD_BYTES=10485760

# Storage roots
INTERESTRIAGE_DB_PATH=/var/lib/interestriage/interestriage.sqlite3
INTERESTRIAGE_BLOB_ROOT=/var/lib/interestriage/blob-store

# Model and audio settings
TTS_ADAPTER=stub
REAL_TTS_PROVIDER=disabled

# Production proxy values
PUBLIC_BASE_URL=https://example.com
LETSENCRYPT_EMAIL=you@example.com
